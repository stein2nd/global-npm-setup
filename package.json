{
  "name": "global-npm-setup",
  "version": "2.0.0",
  "description": "A list of globally installed npm packages managed via package.json for reproducible setup.",
  "author": "Koutarou ISHIKAWA <stein2nd@gmail.com>",
  "main": "install-global.zsh",
  "type": "commonjs",
  "license": "GPL-3.0-or-later",
  "private": true,
  "keywords": [
    "npm",
    "global",
    "packages",
    "setup",
    "dotfiles",
    "ncu"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stein2nd/global-npm-setup.git"
  },
  "homepage": "https://github.com/stein2nd/global-npm-setup#readme",
  "bugs": {
    "url": "https://github.com/stein2nd/global-npm-setup/issues"
  },
  "scripts": {
    "ncu:check": "ncu -g --format time --packageFile package.json",
    "ncu:update": "ncu -g --format time -u --packageFile package.json"
  },
  "dependencies": {
    "corepack": "^0.35.0",
    "editorconfig-cli": "^1.0.0",
    "envinfo": "^7.21.0",
    "npm-check-updates": "^22.2.3",
    "npm": "^11.16.0",
    "run": "^1.5.0",
    "textlint-rule-preset-ja-spacing": "^3.0.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-spellcheck-tech-word": "^5.0.0",
    "textlint": "^15.7.1",
    "wp-handbook-converter": "^1.0.0",
    "wpapi": "^1.2.2"
  }
}
